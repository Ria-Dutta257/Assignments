<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="dept" class="com.capgemini.employee.Department">
        <property name="departmentId" value="10"/>
        <property name="departmentName" value="IT"/>
    </bean>

    <bean id="emp" class="com.capgemini.employee.Employee">
        <property name="employeeId" value="101"/>
        <property name="employeeName" value="John"/>
        <property name="salary" value="50000"/>
        <property name="department" ref="dept"/>
    </bean>

</beans>