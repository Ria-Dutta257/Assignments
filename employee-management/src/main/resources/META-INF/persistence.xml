<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
 version="2.2">

<persistence-unit name="employeePU">

<provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

<class>com.example.entity.Employee</class>
<class>com.example.entity.SalaryRecord</class>
<class>com.example.entity.PerformanceReview</class>

<properties>

<property name="javax.persistence.jdbc.driver"
value="org.postgresql.Driver"/>

<property name="javax.persistence.jdbc.url"
value="jdbc:postgresql://localhost:5432/employee_db"/>

<property name="javax.persistence.jdbc.user"
value="postgres"/>

<property name="javax.persistence.jdbc.password"
value="Ria@123"/>

<property name="hibernate.dialect"
value="org.hibernate.dialect.PostgreSQLDialect"/>

<property name="hibernate.hbm2ddl.auto"
value="update"/>

<property name="hibernate.show_sql"
value="true"/>

</properties>

</persistence-unit>
</persistence>